# MISTRAL_API_KEY: Recommended server-side Mistral API key.
# The mobile app can also store a user-provided key locally, but keeping it on the server is safer.
MISTRAL_API_KEY="YOUR_MISTRAL_API_KEY"

# VITE_API_BASE_URL: Optional public backend base URL for packaged mobile builds.
# Leave blank during local development when Vite proxies /api to the Express server.
VITE_API_BASE_URL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
