# MISTRAL_API_KEY: Recommended server-side Mistral API key.
# The mobile app can also store a user-provided key locally, but keeping it on the server is safer.
MISTRAL_API_KEY="YOUR_MISTRAL_API_KEY"

# COQUI_API_URL: OpenAI-compatible Coqui speech endpoint.
# Default local Docker deployment: http://127.0.0.1:5002/v1/audio/speech
COQUI_API_URL="http://127.0.0.1:5002/v1/audio/speech"

# COQUI_API_KEY: Optional bearer token if your Coqui endpoint is protected.
COQUI_API_KEY=""

# COQUI_MODEL: Model name sent to the Coqui OpenAI-compatible endpoint.
COQUI_MODEL="xtts_v2"

# COQUI_VOICE: Voice reference path as seen by the Coqui container.
# The included Docker setup mounts ./tts-data/reference to /voices.
COQUI_VOICE="/voices/MaakaPohatu.mp3"

# COQUI_LANGUAGE: Default language sent to the fallback XTTS JSON mode.
COQUI_LANGUAGE="en"

# COQUI_RESPONSE_FORMAT: Audio format returned by the Coqui endpoint.
COQUI_RESPONSE_FORMAT="mp3"

# COQUI_TIMEOUT_MS: Upstream TTS timeout in milliseconds.
COQUI_TIMEOUT_MS="120000"

# VITE_API_PROXY_TARGET: Local proxy target used by the Vite dev server.
VITE_API_PROXY_TARGET="http://127.0.0.1:8787"

# VITE_API_BASE_URL: Public backend base URL for packaged mobile builds.
# Set this to the host serving /api/tts, not the raw Coqui container.
VITE_API_BASE_URL=""

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
