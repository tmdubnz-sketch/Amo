# MISTRAL_API_KEY: Recommended server-side Mistral API key.
# The mobile app can also store a user-provided key locally, but keeping it on the server is safer.
MISTRAL_API_KEY="YOUR_MISTRAL_API_KEY"

# OPENAI_API_KEY: For OpenAI TTS (fast, high quality).
# Valid values: alloy, echo, fable, onyx, nova, shimmer, coral
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# OPENAI_TTS_MODEL: OpenAI TTS model (tts-1 or tts-1-hd for higher quality)
OPENAI_TTS_MODEL="tts-1"

# COQUI_API_URL: OpenAI-compatible Coqui speech endpoint (optional alternative).
# Default local Docker deployment: http://127.0.0.1:5002/v1/audio/speech
COQUI_API_URL=""

# COQUI_API_KEY: Optional bearer token if your Coqui endpoint is protected.
COQUI_API_KEY=""

# COQUI_MODEL: Model name sent to the Coqui OpenAI-compatible endpoint.
COQUI_MODEL="xtts_v2"

# COQUI_VOICE: Voice reference path as seen by the Coqui container.
# The included Docker setup mounts ./tts-data/reference to /voices.
COQUI_VOICE="/voices/MaakaPohatu.mp3"

# TTS_VOICE_MAP: Optional JSON map for persona voice ids to backend voices.
# For OpenAI TTS: {"bm_george":"alloy","bf_emma":"nova"}
# For XTTS: {"bm_george":"/voices/male.wav","bf_emma":"/voices/female.wav"}
TTS_VOICE_MAP='{"bm_george":"alloy","bf_emma":"nova"}'

# COQUI_LANGUAGE: Default language sent to the fallback XTTS JSON mode.
COQUI_LANGUAGE="en"

# COQUI_RESPONSE_FORMAT: Audio format returned by the Coqui endpoint.
COQUI_RESPONSE_FORMAT="mp3"

# COQUI_TIMEOUT_MS: Upstream TTS timeout in milliseconds.
COQUI_TIMEOUT_MS="120000"

# VITE_API_PROXY_TARGET: Local proxy target used by the Vite dev server.
VITE_API_PROXY_TARGET="http://127.0.0.1:8787"

# VITE_API_BASE_URL: Public backend base URL for packaged mobile builds.
# Set this to the host serving /api/tts and /api/stt, not the raw Coqui container.
# Android emulator example: http://10.0.2.2:8787
# Physical Android device example: http://YOUR-LAN-IP:8787
VITE_API_BASE_URL=""

# STT_BACKEND_MODE: 'whisper-asr' for local Docker Whisper, 'openai' for hosted OpenAI-compatible STT.
STT_BACKEND_MODE="whisper-asr"

# STT_API_URL: Whisper STT endpoint or OpenAI-compatible /audio/transcriptions endpoint.
STT_API_URL="http://127.0.0.1:9000/asr"

# STT_API_KEY: Only required for hosted OpenAI-compatible STT backends.
STT_API_KEY=""

# STT_MODEL: Used by OpenAI-compatible STT backends.
STT_MODEL="gpt-4o-mini-transcribe"

# STT_TIMEOUT_MS: Upstream STT timeout in milliseconds.
STT_TIMEOUT_MS="120000"

# STT_WHISPER_MODEL: Docker Whisper model size for docker-compose.stt.yml.
STT_WHISPER_MODEL="small"

# STT_WHISPER_ENGINE: 'faster_whisper' recommended for local CPU inference.
STT_WHISPER_ENGINE="faster_whisper"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
