{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:web": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "cap:sync": "npx cap sync",
    "android:add": "npx cap add android",
    "android:open": "npx cap open android",
    "android:build": "npm run build && npx cap sync android",
    "dev:api": "node server/index.mjs",
    "start:api": "node server/index.mjs",
    "dev:piper": "bash scripts/setup-piper.sh && node server/index-piper.mjs",
    "dev:ttsai": "node server/server-ttsai.mjs",
    "dev:coqui": "docker compose -f docker-compose.coqui.yml up",
    "dev:coqui:down": "docker compose -f docker-compose.coqui.yml down",
    "dev:stt": "docker compose -f docker-compose.stt.yml up",
    "dev:stt:down": "docker compose -f docker-compose.stt.yml down"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/browser": "^7.0.2",
    "@capacitor/cli": "^7.4.2",
    "@capacitor/core": "^7.4.2",
    "@capacitor/preferences": "^7.0.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
